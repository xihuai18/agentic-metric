/* agentic-metric TUI — theme-aware styles.
 *
 * Only Textual semantic variables are used here ($surface, $panel,
 * $boost, $primary, $accent, $warning, $success, $text, $text-muted,
 * $border). That lets Textual's theme machinery pick concrete colors
 * from whatever theme the user chose (default: textual-dark; override
 * via the App's theme setter or ``TEXTUAL_THEME=<name>``).
 *
 * Widget-level text colors are set in Python using 8-color ANSI names
 * so they follow the terminal's palette instead of hard-coding hex.
 */

Header {
    background: $boost;
    color: $text;
}

Footer {
    background: $boost;
    color: $text;
}

Footer > .footer--key {
    background: $warning;
    color: $surface;
    text-style: bold;
}

/* Highlight the R binding in the footer while auto-refresh is running.
 * Both the key cell and the "Auto" label light up so the active state
 * is obvious at a glance. */
FooterKey.-auto-on {
    background: $warning;
    .footer-key--key {
        color: $surface;
        background: $success;
        text-style: bold;
    }
    .footer-key--description {
        color: $surface;
        background: $warning;
        text-style: bold;
    }
}

/* ─── Top summary row: 3 cells side by side ─── */

#summary-row {
    height: 7;
    min-height: 5;
    margin: 1 1 0 1;
}

SummaryCell {
    width: 1fr;
    height: 1fr;
    margin: 0 1;
    padding: 0 2;
    border: round white;
    content-align: left top;
}

SummaryCell.-focused {
    border: round $warning;
    background: $panel-lighten-1;
}

/* ─── Hourly heatmap (today only) ─── */

#heatmap-panel {
    height: 7;
    margin: 0 1;
    padding: 0 1;
    border: round white;
}

#heatmap-title {
    height: 1;
    color: $text;
    text-style: bold;
}

#heatmap {
    height: 3;
}

#driver-line {
    height: 1;
    color: $text;
}

/* ─── Chart ─── */

#chart-panel {
    height: 1fr;
    min-height: 7;
    max-height: 15;
    margin: 0 1;
    padding: 0 1;
    border: round white;
}

#chart-title {
    height: 1;
    color: $text;
    text-style: bold;
}

#chart {
    height: 1fr;
}

/* ─── Breakdown ─── */

#breakdown-panel {
    height: 1fr;
    min-height: 4;
    margin: 0 1 1 1;
    padding: 0 1;
    border: round white;
}

#breakdown-title {
    height: 1;
    color: $text;
    text-style: bold;
}

#breakdown-body {
    height: 1fr;
}
